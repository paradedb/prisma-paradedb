{
  "name": "@prisma-next/extension-paradedb",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "0.5.0-dev.85",
    "@prisma-next/contract-authoring": "0.5.0-dev.85",
    "@prisma-next/family-sql": "0.5.0-dev.85",
    "@prisma-next/framework-components": "0.5.0-dev.85",
    "@prisma-next/sql-contract": "0.5.0-dev.85",
    "@prisma-next/sql-operations": "0.5.0-dev.85",
    "@prisma-next/sql-relational-core": "0.5.0-dev.85",
    "@prisma-next/sql-runtime": "0.5.0-dev.85",
    "arktype": "^2.1.25"
  },
  "devDependencies": {
    "@prisma-next/adapter-postgres": "0.5.0-dev.85",
    "@prisma-next/operations": "0.5.0-dev.85",
    "@prisma-next/sql-contract-ts": "0.5.0-dev.85",
    "tsdown": "0.22.0",
    "typanion": "3.14.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./control": "./dist/control.mjs",
    "./index-types": "./dist/index-types.mjs",
    "./operation-types": "./dist/operation-types.mjs",
    "./pack": "./dist/pack.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paradedb/prisma-paradedb.git",
    "directory": "paradedb"
  }
}
